msgstr "اختر السجل الذي يصف حالتك الحالية بشكل أفضل. ستراجعه العيادات لتقييم التوافق."

#: templates/recommendations/questionnaire.html:1076
msgid "Create New Medical Record"
msgstr "إنشاء سجل طبي جديد"

#: templates/recommendations/questionnaire.html:1088
msgid "No diagnosis noted"
msgstr "لا يوجد تشخيص مدوّن"

#: templates/recommendations/questionnaire.html:1096
msgid "No medical records yet"
msgstr "لا توجد سجلات طبية بعد"

#: templates/recommendations/questionnaire.html:1097
msgid "You need to create a medical record first before sending requests to clinics."
msgstr "تحتاج إلى إنشاء سجل طبي أولاً قبل إرسال الطلبات إلى العيادات."

#: templates/recommendations/questionnaire.html:1099
msgid "Create Medical Record"
msgstr "إنشاء سجل طبي"

#: templates/recommendations/questionnaire.html:1105
msgid "Please select a medical record."
msgstr "يرجى اختيار سجل طبي."

#: templates/recommendations/questionnaire.html:1117
msgid "Step 3 of 4"
msgstr "الخطوة 3 من 4"

#: templates/recommendations/questionnaire.html:1118
msgid "Where would you like to receive treatment?"
msgstr "أين تودّ تلقي العلاج؟"

#: templates/recommendations/questionnaire.html:1119
msgid "Pick a continent to see available countries, then select the specific countries you're open to."
msgstr "اختر قارة لعرض الدول المتاحة، ثم حدد الدول التي تناسبك."

#: templates/recommendations/questionnaire.html:1122
msgid "Select continent"
msgstr "اختر القارة"

#: templates/recommendations/questionnaire.html:1126
msgid "All continents"
msgstr "جميع القارات"

#: templates/recommendations/questionnaire.html:1140
msgid "Select country"
msgstr "اختر الدولة"

#: templates/recommendations/questionnaire.html:1145
msgid "Please select at least one continent and one country."
msgstr "يرجى اختيار قارة واحدة ودولة واحدة على الأقل."

#: templates/recommendations/questionnaire.html:1157
msgid "Step 4 of 5"
msgstr "الخطوة 4 من 5"

#: templates/recommendations/questionnaire.html:1158
msgid "Do you need accommodation support?"
msgstr "هل تحتاج إلى دعم في الإقامة؟"

#: templates/recommendations/questionnaire.html:1159
msgid "Choose your accommodation preference. If accommodation is required, include expected companions and treatment dates."
msgstr "اختر تفضيل الإقامة. إذا كانت الإقامة مطلوبة، أضف عدد المرافقين المتوقع وتواريخ العلاج."

#: templates/recommendations/questionnaire.html:1165
msgid "Select accommodation type"
msgstr "اختر نوع الإقامة"

#: templates/recommendations/questionnaire.html:1166
msgid "No accommodation"
msgstr "بدون إقامة"

#: templates/recommendations/questionnaire.html:1174
msgid "Companions count"
msgstr "عدد المرافقين"

#: templates/recommendations/questionnaire.html:1182
msgid "I will come alone"
msgstr "سآتي وحدي"

#: templates/recommendations/questionnaire.html:1197
msgid "Please select accommodation type and valid treatment dates. Companions count is required when accommodation is needed."
msgstr "يرجى اختيار نوع الإقامة وتواريخ علاج صالحة. عدد المرافقين مطلوب عند الحاجة إلى إقامة."

#: templates/recommendations/questionnaire.html:1209
msgid "Step 5 of 5"
msgstr "الخطوة 5 من 5"

#: templates/recommendations/questionnaire.html:1210
msgid "What treatment or service do you need?"
msgstr "ما العلاج أو الخدمة التي تحتاجها؟"

#: templates/recommendations/questionnaire.html:1211
msgid "Describe the treatment, procedure, or therapy you're looking for. Be as specific as you like — the more detail, the better the match."
msgstr "صِف العلاج أو الإجراء أو التأهيل الذي تبحث عنه. كن دقيقًا بقدر ما تشاء — كلما زادت التفاصيل، كانت المطابقة أفضل."

#: templates/recommendations/questionnaire.html:1214
msgid "Quick picks"
msgstr "اختيارات سريعة"

#: templates/recommendations/questionnaire.html:1216
msgid "Neuro rehab"
msgstr "تأهيل عصبي"

#: templates/recommendations/questionnaire.html:1217
msgid "Orthopedic surgery"
msgstr "جراحة عظام"

#: templates/recommendations/questionnaire.html:1218
msgid "Post-op recovery"
msgstr "تعافٍ بعد الجراحة"

#: templates/recommendations/questionnaire.html:1219
msgid "Cardiac rehab"
msgstr "تأهيل قلبي"

#: templates/recommendations/questionnaire.html:1220
msgid "Oncology"
msgstr "الأورام"

#: templates/recommendations/questionnaire.html:1221
msgid "Physical therapy"
msgstr "علاج طبيعي"

#: templates/recommendations/questionnaire.html:1222
msgid "Spinal treatment"
msgstr "علاج العمود الفقري"

#: templates/recommendations/questionnaire.html:1228
msgid "e.g. knee replacement, stroke rehabilitation, IVF treatment…"
msgstr "مثال: استبدال ركبة، تأهيل بعد جلطة، علاج أطفال الأنابيب…"

#: templates/recommendations/questionnaire.html:1231
msgid "Please describe the treatment or service you need."
msgstr "يرجى وصف العلاج أو الخدمة التي تحتاجها."

#: templates/recommendations/questionnaire.html:1236
msgid "Find Matching Clinics"
msgstr "البحث عن العيادات المطابقة"

#: templates/recommendations/questionnaire.html:1255
msgid "No clinic types available."
msgstr "لا توجد أنواع عيادات متاحة."

#: templates/recommendations/questionnaire.html:1256
#, python-brace-format
msgid "Clinics specializing in {name} care and treatments."
msgstr "عيادات متخصصة في رعاية وعلاجات {name}."

#: templates/recommendations/questionnaire.html:1257
msgid "Medical record created and selected!"
msgstr "تم إنشاء السجل الطبي واختياره!"

#: templates/recommendations/questionnaire.html:1258
msgid "All countries"
msgstr "جميع الدول"

#: templates/recommendations/questionnaire.html:1259
#, python-brace-format
msgid "{count} countries available — select any combination"
msgstr "{count} دولة متاحة — اختر أي مجموعة"

#: templates/recommendations/questionnaire.html:1260
msgid "No countries available for this continent."
msgstr "لا توجد دول متاحة لهذه القارة."

#: templates/recommendations/questionnaire.html:1262
#, python-brace-format
msgid "No results for \"{query}\""
msgstr "لا توجد نتائج لـ \"{query}\""

