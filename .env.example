# Copy to .env for local development (.env is gitignored — never commit it).
# In production, set these as host/platform environment variables instead.

# ── Django core ───────────────────────────────────────────────
# Local dev: leave DEBUG=True. PRODUCTION: must be False.
DEBUG=True

# REQUIRED in production (DEBUG=False). Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# Leave blank locally to use the built-in dev fallback.
SECRET_KEY=

# REQUIRED to encrypt medical-report files at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank locally to use the dev fallback (derived from SECRET_KEY — dev only).
ENCRYPTION_KEY=

# Comma-separated. Add your production host(s), e.g. nero.onrender.com,nero.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Extra HTTPS origins to trust for CSRF, if not already covered by ALLOWED_HOSTS.
# e.g. https://nero.onrender.com
CSRF_TRUSTED_ORIGINS=

SITE_ID=1

# ── Database (for the Postgres migration step; SQLite is used if unset) ──
# e.g. postgres://USER:PASS@HOST/dbname?sslmode=require
# DATABASE_URL=

# ── Google OAuth (optional for social login) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Calendar OAuth (required for Add to Google Calendar buttons) ──
# Use a dedicated OAuth client from Google Cloud Console.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Optional calendar id. Keep 'primary' for the authenticated Google account calendar.
GOOGLE_CALENDAR_ID=primary

# Optional: force OAuth redirect base URL to avoid redirect_uri_mismatch
# Examples: http://localhost:8000 or https://your-domain.com
GOOGLE_CALENDAR_REDIRECT_BASE=

# Add these callback URLs in Google Cloud OAuth redirect URIs:
# - http://localhost:8000/clinics/google-calendar/callback/
# - http://localhost:8000/patients/google-calendar/callback/
